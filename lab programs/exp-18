import pandas as pd

data = {
'City':['A','B','C'],
'Temp1':[30,25,28],
'Temp2':[32,26,27],
'Temp3':[31,24,29]
}

df = pd.DataFrame(data)

mean_temp = df.iloc[:,1:].mean(axis=1)

std_temp = df.iloc[:,1:].std(axis=1)

temp_range = df.iloc[:,1:].max(axis=1) - df.iloc[:,1:].min(axis=1)

print("Mean Temperature\n",mean_temp)
print("Standard Deviation\n",std_temp)
print("Temperature Range\n",temp_range)
