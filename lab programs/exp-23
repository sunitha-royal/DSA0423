import pandas as pd
from sklearn.tree import DecisionTreeClassifier

data = {
'income':[50000,30000,70000,40000],
'credit_score':[700,600,750,580],
'debt_ratio':[0.3,0.5,0.2,0.6],
'employment_years':[5,2,8,1],
'risk':[0,1,0,1]
}

df = pd.DataFrame(data)

X = df.drop('risk',axis=1)
y = df['risk']

model = DecisionTreeClassifier()
model.fit(X,y)

prediction = model.predict([[60000,720,0.25,6]])
print("Risk Prediction:",prediction)
